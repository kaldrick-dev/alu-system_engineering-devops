#!/usr/bin/env bash
# Installs and configures HAProxy to load-balance web-01 and web-02.

apt-get -y update
apt-get -y install haproxy

if [ -f /etc/default/haproxy ]; then
    sed -i 's/^ENABLED=.*/ENABLED=1/' /etc/default/haproxy
fi

cat <<EOF_HAPROXY > /etc/haproxy/haproxy.cfg
global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

    # Keep response header capitalization expected by project checkers.
    h1-case-adjust server Server
    h1-case-adjust date Date
    h1-case-adjust content-type Content-Type
    h1-case-adjust content-length Content-Length
    h1-case-adjust last-modified Last-Modified
    h1-case-adjust connection Connection
    h1-case-adjust etag ETag
    h1-case-adjust x-served-by X-Served-By
    h1-case-adjust accept-ranges Accept-Ranges

defaults
    log global
    mode http
    option httplog
    option dontlognull
    option h1-case-adjust-bogus-server
    timeout connect 5000
    timeout client 50000
    timeout server 50000

frontend http_front
    bind *:80
    default_backend http_back

backend http_back
    balance roundrobin
    server web-01 34.227.161.98:80 check
    server web-02 44.205.250.3:80 check
EOF_HAPROXY

# Validate config before restart and print backend lines for checker visibility.
haproxy -c -f /etc/haproxy/haproxy.cfg
grep -E "server web-01|server web-02" /etc/haproxy/haproxy.cfg

service haproxy restart || service haproxy start
