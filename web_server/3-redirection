#!/usr/bin/env bash
# Installs nginx and configures a 301 redirect from /redirect_me.

set -e

apt-get -y update
apt-get -y install nginx

echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

if ! grep -q "rewrite \^/redirect_me" /etc/nginx/sites-available/default; then
  sed -i '/server_name _;/a\    rewrite ^/redirect_me https://www.youtube.com/watch?v=QH2-TGUlwu4 permanent;' /etc/nginx/sites-available/default
fi

service nginx restart || service nginx start
